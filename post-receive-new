#!/bin/bash
TARGET="/home/ubuntu/DICEwithoutNumber"
GIT_DIR="/home/ubuntu/bot.git"

# Sync branch metadata
git --git-dir=$GIT_DIR symbolic-ref HEAD refs/heads/main

# Force checkout using sudo to ensure permissions
sudo git --work-tree=$TARGET --git-dir=$GIT_DIR checkout -f main
echo "Code deployed to $TARGET"

# HARDEN: Restore ownership to ubuntu user after checkout
echo "Restoring ownership to ubuntu user..."
sudo chown -R ubuntu:ubuntu $TARGET

# Restart
sudo systemctl daemon-reload
sudo systemctl restart dicewithoutnumber.service
echo "Service restarted."
